{
  "type": "object",
  "properties": {
    "settings": {
      "type": "object",
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "fps": { "type": "integer", "minimum": 1 },
        "durationInFrames": { "type": "integer", "minimum": 1 }
      },
      "required": ["width", "height", "fps", "durationInFrames"],
      "additionalProperties": false
    },
    "assets": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "timeline": {
      "type": "object",
      "properties": {
        "clips": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "assetId": { "type": "string", "minLength": 1 },
              "startFrame": { "type": "integer", "minimum": 0 },
              "endFrame": { "type": "integer", "minimum": 1 },
              "trimStart": { "type": "integer", "minimum": 0 },
              "trimEnd": { "type": "integer", "minimum": 1 },
              "transition": { "type": "string" }
            },
            "required": ["id", "assetId", "startFrame", "endFrame"],
            "additionalProperties": false
          }
        },
        "texts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "content": { "type": "string" },
              "startFrame": { "type": "integer", "minimum": 0 },
              "endFrame": { "type": "integer", "minimum": 1 },
              "style": {
                "type": "object",
                "properties": {
                  "color": { "type": "string" },
                  "fontSize": { "type": "integer", "minimum": 1 }
                }
              },
              "position": {
                "type": "object",
                "properties": {
                  "x": { "enum": ["left", "center", "right"] },
                  "y": { "enum": ["top", "center", "bottom"] }
                }
              },
              "effect": { "enum": ["none", "kinetic", "liquid", "shader", "typewriter", "wave", "glitch", "bounce", "scale", "flash", "pulse", "slide-left", "slide-right"] },
              "bg": { "type": "string" },
              "accent": { "type": "string" }
            },
            "required": ["id", "content", "startFrame", "endFrame"],
            "additionalProperties": false
          }
        },
        "audio": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "assetId": { "type": "string", "minLength": 1 },
              "startFrame": { "type": "integer", "minimum": 0 },
              "duration": { "type": "integer", "minimum": 1 },
              "volume": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "required": ["id", "assetId", "startFrame", "duration", "volume"],
            "additionalProperties": false
          }
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "value": { "type": "number" },
              "color": { "type": "string" },
              "metadata": { "type": "object" }
            },
            "required": ["id", "label", "value"]
          }
        }
      },
      "required": ["clips", "texts", "audio"],
      "additionalProperties": false
    }
  },
  "required": ["settings", "assets", "timeline"],
  "additionalProperties": false
}
